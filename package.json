{
  "name": "paper-generation",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev:mobile": "turbo -F mobile dev",
    "dev:server": "turbo -F server dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @paper-generation/db db:push",
    "db:studio": "turbo -F @paper-generation/db db:studio",
    "db:generate": "turbo -F @paper-generation/db db:generate",
    "db:migrate": "turbo -F @paper-generation/db db:migrate",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=18"
  }
}
